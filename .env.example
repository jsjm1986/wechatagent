# ──────────────────────────────────────────────────────────────────────────────
# WechatAgent 配置示例。仅 MCP_API_KEY / OPENAI_API_KEY 必填，其余有默认值。
# 完整字段在 src/config.rs；本文件按运维上手优先级分组。
# ──────────────────────────────────────────────────────────────────────────────

# ── 应用基础 ──────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=wechatagent

# ── MCP 工具网关（微信账号 / 联系人 / 发送）──────────────────────────────────
MCP_BASE_URL=http://47.108.57.147:3001
MCP_API_KEY=replace-with-account-key

# ── LLM（OpenAI 协议；DeepSeek / Qwen 等同协议复用本组）────────────────────
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=replace-with-deepseek-key
OPENAI_MODEL=deepseek-v4-flash
# LLM 调用超时（秒）。
LLM_TIMEOUT_SECONDS=45
# 单次 generate_agent_json 最大重试次数（指数退避，JSON 错误不重试）。
LLM_MAX_RETRIES=5
# 重试基础间隔毫秒；实际间隔 = base * 2^(attempt-1) + jitter。
LLM_RETRY_BASE_MS=1500

# ── Workspace / Account 默认 ─────────────────────────────────────────────────
DEFAULT_WORKSPACE_ID=default
DEFAULT_ACCOUNT_ID=default

# ── Agent 决策行为参数 ────────────────────────────────────────────────────────
# 装 prompt 时携带的最近 inbound/outbound 消息数。
AGENT_RECENT_MESSAGE_LIMIT=12
# 同一 contact 两次 outbound 之间最小间隔（秒）；低于则 gateway 拒发。
AGENT_MIN_REPLY_INTERVAL_SECONDS=20
# 单条出站消息软上限字符数；回复超过则按句末标点拆成多条短消息（更像微信分条发）。
AGENT_REPLY_MAX_SEGMENT_CHARS=120
# 单次回复最多拆成几条短消息；超出则尾部合并回最后一段，避免刷屏。
AGENT_REPLY_MAX_SEGMENTS=4
# ── 作息门控（#69）：静默时段。默认关停（灰度，代码上线 ≠ 行为生效）。──
# 开启后客户在静默时段发来的消息不立即回，排队到醒来时段一次性回复；
# 主动发送（planner/follow_up）若在静默时段到点则重排到醒来时刻。relay 转述豁免。
# 时区 = 运营方部署进程本地时区（chrono::Local），不需单独配置。
QUIET_HOURS_ENABLED=false
# 静默起点小时（0..=23，含）。
QUIET_HOURS_START=22
# 静默终点 / 醒来小时（0..=23，不含）。start==end 退化为永不静默；start>end 表示跨午夜。
QUIET_HOURS_END=8

# ── Worker 调度 ──────────────────────────────────────────────────────────────
# follow-up task worker 轮询间隔（秒）。
TASK_WORKER_INTERVAL_SECONDS=30
# task running 状态超时回收阈值（秒）。
TASK_CLAIM_TIMEOUT_SECONDS=300
# reaction_analysis claim 锁超时（秒）。
REACTION_ANALYSIS_CLAIM_TIMEOUT_SECONDS=60

# ── Webhook 限流 ─────────────────────────────────────────────────────────────
# 单 account 滑窗大小（秒）+ 容量（条），超出走 429。
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_CAPACITY=30

# ── M3 Strategic Planner（静默跟进 / commitment due 扫描器）──────────────────
# 默认关闭；置 true 后 main.rs spawn 一条独立 loop。
STRATEGIC_PLANNER_ENABLED=false
STRATEGIC_PLANNER_INTERVAL_SECONDS=600
STRATEGIC_PLANNER_SILENT_THRESHOLD_HOURS=72
STRATEGIC_PLANNER_DAILY_EMIT_CAP=20
# commitment due 临近窗口（小时），命中则按高优先级生成 follow-up。
STRATEGIC_PLANNER_COMMITMENT_IMMINENT_WINDOW_HOURS=8
# 无显式 due_at 的承诺用 created_at+N 小时合成兜底到期(让 LLM 当前产出的无 due_at
# 承诺也能被跟进)；设 0 禁用兜底(回到"无 due_at 即跳过")。
STRATEGIC_PLANNER_COMMITMENT_FALLBACK_DUE_HOURS=72
# 同 commitment 重复 emit 去重窗口（小时）。
STRATEGIC_PLANNER_COMMITMENT_EMIT_DEDUP_HOURS=24
# stage stagnation 触发：customer_stage 停滞 ≥N 天且最近 inbound ≤M 小时。
STRATEGIC_PLANNER_STAGE_STAGNATION_THRESHOLD_DAYS=14
STRATEGIC_PLANNER_STAGE_STAGNATION_RECENT_INBOUND_HOURS=24
# block rate 监控窗口 + 触发阈值（用于自动暂停 contact 出栈）。
STRATEGIC_PLANNER_BLOCK_RATE_WINDOW_HOURS=24
STRATEGIC_PLANNER_BLOCK_RATE_MIN_RUNS=3
STRATEGIC_PLANNER_BLOCK_RATE_THRESHOLD=0.6
# 是否按 commitment / 静默 / stage 三类优先级排序 emit。
STRATEGIC_PLANNER_PRIORITY_ENABLED=true

# ── Phase D：cold_contact_worker（冷链路重激活）──────────────────────────────
# 默认关闭；按 contacts.last_outbound_at 阈值挑联系人 → peer_case 钩子。
COLD_CONTACT_WORKER_ENABLED=false
COLD_CONTACT_THRESHOLD_HOURS=168
# 每天单 contact 最多 1 次；workspace 维度的日总量上限。
COLD_CONTACT_DAILY_EMIT_CAP=5

# ── agent-self-evolution M4：演化器（独立 worker）────────────────────────────
# 默认 disabled；仅在运维显式打开时才会 spawn 演化器循环。
EVOLUTION_ENABLED=false
EVOLUTION_TICK_SECONDS=21600
EVOLUTION_RUN_TOKEN_BUDGET=60000
EVOLUTION_RUN_MAX_LLM_CALLS=30
# Shadow 评估窗口（小时）+ 最小回放数（少于则不显著）。
EVOLUTION_EVAL_WINDOW_HOURS=72
EVOLUTION_MIN_REPLAYS=30
# 显著性最小提升（送达率 / 自评分）+ 5 闸命中率最大允许上升。
EVOLUTION_MIN_SEND_SUCCESS_DELTA=0.05
EVOLUTION_MIN_SELF_CRITIQUE_DELTA=0.10
EVOLUTION_MAX_5GATE_HIT_INCREASE=0.10
# Replay 并发 + 最大失败率（超过判失败收口）。
EVOLUTION_REPLAY_CONCURRENCY=4
EVOLUTION_REPLAY_MAX_FAIL_RATE=0.30
# 阈值 release 成功后的冷却小时数；同 cohort 抽样上限。
EVOLUTION_THRESHOLD_RELEASE_COOLDOWN_HOURS=24
EVOLUTION_COHORT_PER_CONTACT_CAP=3
EVOLUTION_COHORT_SAMPLE_PER_FAILURE_BUCKET=10

# ── Phase C / C5：threshold_overrides 自动 release（hold_rate close-loop）──
# 默认关闭。置 true 后演化器 tick 末尾扫描 status="eligible_for_release"
# 的 threshold proposal，若回看窗口内 hit_rate 仍在异常区间 → 自动调
# release_threshold（admin id="evolution_auto_release"）。rollback 永远人工——
# Requirements 9.7 不允许自动回滚。
EVOLUTION_AUTO_RELEASE_ENABLED=false
EVOLUTION_AUTO_RELEASE_WINDOW_HOURS=336
EVOLUTION_AUTO_RELEASE_PER_TICK_CAP=1

# ── Knowledge Digest Workstation（日报工作站）────────────────────────────────
# 默认关闭；置 true 后每日 RUN_HOUR 触发 generate_today_digest。
KNOWLEDGE_DIGEST_ENABLED=false
KNOWLEDGE_DIGEST_RUN_HOUR=9
KNOWLEDGE_DIGEST_RUN_TOKEN_BUDGET=24000
KNOWLEDGE_DIGEST_RUN_MAX_LLM_CALLS=8
# 与 digest 协同的辅助 worker 间隔（秒）。
KNOWLEDGE_TASK_WORKER_INTERVAL_SECONDS=30
CATALOG_REBUILD_WORKER_INTERVAL_SECONDS=3
# knowledge_wiki feedback_worker 周期（秒），含 lessons_learned 14d 聚合。
KNOWLEDGE_FEEDBACK_INTERVAL_SECONDS=600

# ── Phase E2：Reviewer 双模并行（epistemic diversity）──────────────────────
# 默认关闭。开启后 review_decision 把同一 reviewer prompt 并行喂两路 provider，
# 分歧（评分差≥阈值或 grounding/hallucination 决策不一致）触发 single-shot
# revision；同模无分歧时只走 primary，不增加预算。
REVIEWER_DUAL_ENABLED=false
# 第二 reviewer provider 配置。REVIEWER_DUAL_ENABLED=true 时三项必填，
# 否则 main.rs 启动期 fail-closed。
REVIEWER_SECOND_PROVIDER_BASE_URL=
REVIEWER_SECOND_PROVIDER_API_KEY=
REVIEWER_SECOND_PROVIDER_MODEL=
# 协议 format 仅支持 "openai"（DeepSeek / Qwen 等 OpenAI 协议复用）。
REVIEWER_SECOND_PROVIDER_FORMAT=openai

# ── P0 鉴权 / Session ──────────────────────────────────────────────────
# admin SPA session 有效期（小时）。cookie Max-Age + admin_sessions.expires_at 同步。
SESSION_TTL_HOURS=8
# 部署到 https 时务必设 true，让 Set-Cookie 加 Secure 标志；本地 http 调试可 false。
SESSION_COOKIE_SECURE=false
# 启动时如果 admin_users 集合为空，且这两个 env 都已配，则种入第一个 admin。
# 已存在任何 admin 后即使 env 还在也不会再次种（idempotent）。
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
# 是否对 /webhooks/wechat 校验 X-MCP-Signature（HMAC-SHA256(body, MCP_API_KEY) hex）。
# 默认 true；联调期临时关停可设 false，但生产应保持 true。
WEBHOOK_VERIFY_SIGNATURE=true

# ── Phase G P1-7：公网 JWT 鉴权（RS256，与 cookie session 并存）─────────────
# 默认关闭：middleware 仅认 wa_session cookie。置 true 后还接受
# `Authorization: Bearer <jwt>`，并暴露 POST /api/auth/token 签发。
JWT_ENABLED=false
# 签发的 access token 有效期（分钟）。
JWT_TTL_MINUTES=60
# RS256 私钥 / 公钥 PEM（JWT_ENABLED=true 时两项必填，启动期校验可加载，
# 否则 fail-closed panic——防"以为开了实际没开"）。可用：
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# 多行 PEM 在 .env 里用 \n 转义或换用 docker secret / 挂载文件后读取。
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# ── Phase G P1-6：auto-ingest worker（外部 RSS / HTML 源自动入库）────────────
# 默认关闭。置 true 且 interval>0 时 main.rs spawn ingest_worker_loop，逐租户扫
# ingest_sources（status="active"）→ 条件 GET（If-None-Match）→ feed-rs/scraper
# 解析 → ingest_chunked_text 落 chunk（一律 draft + needs_review，AI 永不自动 verify）。
INGEST_WORKER_ENABLED=false
# worker tick 周期（秒）；单 source 另有 schedule_minutes 自身节流。0 = 关停。
INGEST_WORKER_INTERVAL_SECONDS=3600

# ── 自学习采集管道（第二阶段）：换血 / 健康度 / 召回探索 ───────────────────
# P1 换血（默认 true，立即止血）：dynamic_confidence 的 hit/block 信号取**真实用户
# 反应**（按 run_id join agent_decision_reviews.outcome_status）而非 reviewer 自评
# （review_approved）。沉默/无反应（pending/None/unclassified）一律删失排除，不进分母。
# 设 false 可秒级回滚到旧的 review_approved 统计。
DYNAMIC_CONFIDENCE_REAL_OUTCOME_ENABLED=true
# P3：行为信号采集健康度计数（写入 behavior_signal_metrics，persisted/dedupe_skipped/
# errors 三态 $inc 累加）。默认 false，best-effort 不阻断主链。
BEHAVIOR_SIGNAL_METRICS_ENABLED=false
# P4：知识召回 fallback 排序处的受控探索（top-k 内 softmax 抽样）+ 记录 selection_prob
# （propensity），为未来 off-policy 纠偏留位。默认 false（保持确定性 top-k）。探索只在
# 已验证 verified 池内做，grounding/FactRisk/ProductAccuracy 硬门照常在其后执行。
KNOWLEDGE_EXPLORATION_ENABLED=false
# P4：探索 softmax 温度。越大越接近均匀抽样、越小越接近确定性 argmax。默认 1.0。
KNOWLEDGE_EXPLORATION_TEMPERATURE=1.0
